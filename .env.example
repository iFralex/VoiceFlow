# =============================================================================
# VoiceFlow — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local and fill in the values for local development.
# Never commit .env.local or any file containing real secrets.
# See README.md for the minimum subset required to run `pnpm dev`.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Runtime environment (development | test | production)
NODE_ENV=development

# Public-facing URL of the application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application environment label used for observability (development | staging | production)
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Database (Supabase Postgres via Drizzle)
# -----------------------------------------------------------------------------

# Pooled connection URL used by the application at runtime (via pgBouncer)
DATABASE_URL=postgresql://postgres:your-password@your-project-ref.supabase.co:6543/postgres?pgbouncer=true

# Direct (non-pooled) connection URL used by Drizzle migrations
DATABASE_DIRECT_URL=postgresql://postgres:your-password@your-project-ref.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Project base URL (e.g. https://xxxx.supabase.co) — server-side only
SUPABASE_URL=https://your-project-ref.supabase.co

# Project base URL — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role key — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

# Publishable key — starts with pk_live_ in production, pk_test_ in development
# Used by client-side Stripe.js (optional for hosted Checkout flows)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Secret key — starts with sk_live_ in production, sk_test_ in development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret — starts with whsec_
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs for subscription plans
STRIPE_PRICE_TEST=price_test_placeholder
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_GROWTH=price_growth_placeholder
STRIPE_PRICE_SCALE=price_scale_placeholder

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------

# Resend API key
RESEND_API_KEY=re_your_resend_api_key

# From address used for transactional emails
EMAIL_FROM_ADDRESS=noreply@example.com

# Reply-to address for transactional emails (optional)
EMAIL_REPLY_TO=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------

# Sentry DSN — leave blank to disable Sentry (server-side only)
SENTRY_DSN=

# Sentry DSN — exposed to the browser (same value as SENTRY_DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token — used for sourcemap uploads in CI (optional)
SENTRY_AUTH_TOKEN=

# Sentry org and project slugs — required for sourcemap uploads
SENTRY_ORG=
SENTRY_PROJECT=

# Axiom ingestion token — leave blank to disable Axiom logging
AXIOM_TOKEN=

# Axiom dataset name
AXIOM_DATASET=

# Public URL of the customer-facing status page (e.g. https://status.voiceflow.it)
# When set, a "System status" link appears in the marketing footer and in-app help menu.
NEXT_PUBLIC_STATUS_PAGE_URL=

# -----------------------------------------------------------------------------
# Inngest (background jobs / event-driven workflows)
# -----------------------------------------------------------------------------

# Event key for publishing events to Inngest
INNGEST_EVENT_KEY=your-inngest-event-key

# Signing key for verifying Inngest webhook signatures
INNGEST_SIGNING_KEY=your-inngest-signing-key

# -----------------------------------------------------------------------------
# Voice provider
# -----------------------------------------------------------------------------

# Active voice provider (vapi | retell)
VOICE_PROVIDER=vapi

# Vapi — only required when VOICE_PROVIDER=vapi
# VAPI_ASSISTANT_ID: obtain from Vapi dashboard after creating the "VoiceFlow Outbound Assistant"
# Configure the assistant with ElevenLabs TTS, OpenAI gpt-4o LLM, and webhook URL:
#   ${NEXT_PUBLIC_APP_URL}/api/webhooks/vapi
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_WEBHOOK_SECRET=

# Retell — only required when VOICE_PROVIDER=retell
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Telephony (optional)
# -----------------------------------------------------------------------------

# Twilio — required if using Twilio for PSTN calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Telnyx — alternative PSTN provider
TELNYX_API_KEY=

# Session Border Controller (SBC) for Italian PSTN
SBC_TRUNK_ID=
SBC_AUTH_USER=
SBC_AUTH_PASS=

# CLI rotation caps (optional — shown with their default values)
# Per-CLI maximum dial count per day; reset at 00:05 Europe/Rome by /api/cron/cli-daily-reset
CLI_DAILY_CAP_DEFAULT=100
# Per-CLI sliding-window dial count per hour; enforced inside pickCliForOrg
CLI_HOURLY_CAP_DEFAULT=30

# Weekly SBC smoke-test target (optional — when set, /api/cron/sbc-smoke-test
# and scripts/test-sbc-trunk.ts dial this E.164 number every Sunday 03:00
# Europe/Rome and assert the call connects via the SBC trunk).
SBC_SMOKE_TEST_NUMBER=

# -----------------------------------------------------------------------------
# AI / speech synthesis (optional)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# RPO provider (optional)
# -----------------------------------------------------------------------------

RPO_PROVIDER_API_KEY=
RPO_PROVIDER_ENDPOINT=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Random secret ≥ 32 characters used to sign internal webhook calls
# Generate with: openssl rand -hex 32
INTERNAL_WEBHOOK_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# Random secret ≥ 32 characters used to authenticate the admin credit-adjustment endpoint
# Generate with: openssl rand -hex 32
INTERNAL_ADMIN_TOKEN=change-me-to-a-random-string-of-at-least-32-characters

# Random secret ≥ 16 characters used to authenticate Vercel cron job calls
# Generate with: openssl rand -hex 16
CRON_SECRET=change-me-to-a-random-string

# Credit balance thresholds (optional — shown with their default values)
# Soft threshold: emit a low-balance alert when remaining minutes drop below this
CREDIT_SOFT_THRESHOLD_MINUTES=30
# Hard threshold: block campaign launch when balance (in cents) is below this
CREDIT_HARD_THRESHOLD_CENTS=0
