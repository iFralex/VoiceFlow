# =============================================================================
# VoiceFlow — Environment Variables Reference
# =============================================================================
# Copy this file to .env.local and fill in the values for local development.
# Never commit .env.local or any file containing real secrets.
# See README.md for the minimum subset required to run `pnpm dev`.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Runtime environment (development | test | production)
NODE_ENV=development

# Public-facing URL of the application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application environment label used for observability (development | staging | production)
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Database (Supabase Postgres via Drizzle)
# -----------------------------------------------------------------------------

# Pooled connection URL used by the application at runtime (via pgBouncer)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:6543/postgres?pgbouncer=true

# Direct (non-pooled) connection URL used by Drizzle migrations
DATABASE_DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Project base URL (e.g. https://xxxx.supabase.co) — server-side only
SUPABASE_URL=https://[YOUR-PROJECT].supabase.co

# Project base URL — exposed to the browser
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT].supabase.co

# Anon/public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role key — NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

# Secret key — starts with sk_live_ in production, sk_test_ in development
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Webhook signing secret — starts with whsec_
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs for subscription plans
STRIPE_PRICE_TEST=price_test_placeholder
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_GROWTH=price_growth_placeholder
STRIPE_PRICE_SCALE=price_scale_placeholder

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------

# Resend API key
RESEND_API_KEY=re_your_resend_api_key

# From address used for transactional emails
EMAIL_FROM_ADDRESS=noreply@example.com

# Reply-to address for transactional emails (optional)
EMAIL_REPLY_TO=

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------

# Sentry DSN — leave blank to disable Sentry
SENTRY_DSN=

# Sentry auth token — used for sourcemap uploads in CI (optional)
SENTRY_AUTH_TOKEN=

# Axiom ingestion token — leave blank to disable Axiom logging
AXIOM_TOKEN=

# Axiom dataset name
AXIOM_DATASET=

# -----------------------------------------------------------------------------
# Inngest (background jobs / event-driven workflows)
# -----------------------------------------------------------------------------

# Event key for publishing events to Inngest
INNGEST_EVENT_KEY=your-inngest-event-key

# Signing key for verifying Inngest webhook signatures
INNGEST_SIGNING_KEY=your-inngest-signing-key

# -----------------------------------------------------------------------------
# Voice provider
# -----------------------------------------------------------------------------

# Active voice provider (vapi | retell)
VOICE_PROVIDER=vapi

# Vapi — only required when VOICE_PROVIDER=vapi
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Retell — only required when VOICE_PROVIDER=retell
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Telephony (optional)
# -----------------------------------------------------------------------------

# Twilio — required if using Twilio for PSTN calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Telnyx — alternative PSTN provider
TELNYX_API_KEY=

# Session Border Controller (SBC) for Italian PSTN
SBC_TRUNK_ID=
SBC_AUTH_USER=
SBC_AUTH_PASS=

# -----------------------------------------------------------------------------
# AI / speech synthesis (optional)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# -----------------------------------------------------------------------------
# RPO provider (optional)
# -----------------------------------------------------------------------------

RPO_PROVIDER_API_KEY=
RPO_PROVIDER_ENDPOINT=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Random secret ≥ 32 characters used to sign internal webhook calls
# Generate with: openssl rand -hex 32
INTERNAL_WEBHOOK_SECRET=change-me-to-a-random-string-of-at-least-32-characters
