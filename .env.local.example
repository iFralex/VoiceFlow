# =============================================================================
# VoiceFlow — Developer-Local Overrides
# =============================================================================
# Copy this file to .env.local and fill in values for your local machine.
# Settings here override .env (if present) and take effect during `pnpm dev`.
# Only include variables that differ from the defaults in .env.example.
# =============================================================================

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# Local Supabase instance (from `supabase start`)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?pgbouncer=true
# DATABASE_DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Stripe test mode keys (required — use test-mode keys from Stripe dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Resend test / sandbox (required — use sandbox API key from Resend dashboard)
RESEND_API_KEY=re_placeholder
EMAIL_FROM_ADDRESS=dev@example.com

# Inngest dev server (use literal "local" — the Inngest dev server accepts this)
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=local

# Internal secret — any 32+ char string works locally
INTERNAL_WEBHOOK_SECRET=local-dev-secret-at-least-32-chars-long
